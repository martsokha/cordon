# Rank titles, keyed by `rank-{scheme}-{rank}` where scheme is the
# faction's `rank_scheme` and rank is the tier name (novice,
# experienced, veteran, master, legend).
#
# A faction's rank_scheme decides which set its NPCs use.

# Military — Garrison.
rank-military-novice = Grunt
rank-military-experienced = Soldier
rank-military-veteran = Veteran
rank-military-master = Officer
rank-military-legend = Commander

# Loose — Syndicate, Drifters.
rank-loose-novice = Rookie
rank-loose-experienced = Seasoned
rank-loose-veteran = Hardened
rank-loose-master = Boss
rank-loose-legend = Legend

# Religious — Devoted.
rank-religious-novice = Pilgrim
rank-religious-experienced = Acolyte
rank-religious-veteran = Keeper
rank-religious-master = Prophet
rank-religious-legend = Ascended

# Academic — Institute.
rank-academic-novice = Recruit
rank-academic-experienced = Researcher
rank-academic-veteran = Senior
rank-academic-master = Director
rank-academic-legend = Council
