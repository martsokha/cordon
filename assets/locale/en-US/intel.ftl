# Intel display text.
#
# Each intel entry has a `_title` and a `_description` keyed off
# its ID in `assets/data/intel/*.json`. The laptop's intel tab
# reads both and renders title + dimmer description per entry.

intel_anomaly_surge_detected_title = Anomaly surge detected
intel_anomaly_surge_detected_description = Relic traces are spiking in the outer sectors. Runners report anomalies shifting — routes that were safe yesterday aren't today.

intel_black_market_deal_title = Black market deal
intel_black_market_deal_description = Syndicate middlemen are moving unlicensed goods through the Zone. Prices are soft for buyers who don't ask where it came from.

intel_creature_migration_title = Creature migration
intel_creature_migration_description = Something spooked the mutants. A pack is moving through the wastes — stay clear, or pick over what they leave behind.

intel_faction_war_brewing_title = Faction war brewing
intel_faction_war_brewing_description = Two factions are edging toward open conflict. Expect patrols to thicken and neutral traffic to thin.

intel_garrison_patrol_route_title = Garrison patrol route
intel_garrison_patrol_route_description = Garrison squads are sweeping a predictable corridor this week. Cross them and your standing takes a hit; avoid them and you lose a shortcut.

intel_supply_shortage_title = Supply shortage
intel_supply_shortage_description = One of the factions can't source a staple and is paying over the odds. Check your stash — there's margin here for a few days.

intel_syndicate_smuggling_op_title = Syndicate smuggling op
intel_syndicate_smuggling_op_description = The Syndicate is running a convoy through the far side of the Zone. Interfere, trade with them, or stay out — every choice has a tell.
